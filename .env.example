# =============================================
# Environment Variables - Portaldot Blockchain
# =============================================

# === Blockchain / Node ===
NEXT_PUBLIC_PORTALDOT_WS=wss://mainnet.portaldot.io
NEXT_PUBLIC_PORTALDOT_SS58_FORMAT=42
NEXT_PUBLIC_PORTALDOT_TOKEN_NAME=POT
NEXT_PUBLIC_PORTALDOT_TOKEN_DECIMALS=14
NEXT_PUBLIC_PORTALDOT_CHAIN_NAME=Portaldot

# === Network Selection: mainnet | testnet ===
NEXT_PUBLIC_NETWORK=mainnet

# === App Info ===
NEXT_PUBLIC_APP_NAME=POTRimence
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === API Config (if using REST proxy) ===
PORTALDOT_RPC_HTTP=https://rpc.portaldot.io
API_SECRET_KEY=your_api_secret_here

# === Database (optional for indexer) ===
DATABASE_URL=postgresql://user:pass@localhost:5432/potrimence

# === IPFS (for metadata storage) ===
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/
IPFS_PROJECT_ID=
IPFS_PROJECT_SECRET=
